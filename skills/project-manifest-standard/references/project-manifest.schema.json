{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SylphxAI/skills/blob/main/skills/project-manifest-standard/references/project-manifest.schema.json",
  "title": "Canonical project manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "project",
    "intent",
    "boundaries",
    "architecture",
    "documentation",
    "delivery",
    "commercial",
    "adoption"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 2 },
    "kind": { "const": "ProjectManifest" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repository",
        "name",
        "summary",
        "lifecycle",
        "layer",
        "visibility",
        "policyPool",
        "links"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "repository": { "type": "string", "minLength": 3 },
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 20 },
        "lifecycle": {
          "enum": ["incubating", "active", "production", "commercial", "maintenance", "deprecated", "archived"]
        },
        "layer": { "$ref": "#/$defs/id" },
        "visibility": { "enum": ["private", "internal", "public"] },
        "policyPool": { "$ref": "#/$defs/id" },
        "links": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goals", "nonGoals"],
      "properties": {
        "goals": { "$ref": "#/$defs/nonEmptyStrings" },
        "nonGoals": { "$ref": "#/$defs/nonEmptyStrings" }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owns", "doesNotOwn", "publicSurfaces", "allowedDependencies", "forbiddenCouplings"],
      "properties": {
        "owns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ownedCapability" }
        },
        "doesNotOwn": { "$ref": "#/$defs/nonEmptyStrings" },
        "publicSurfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/publicSurface" }
        },
        "allowedDependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency" }
        },
        "forbiddenCouplings": { "$ref": "#/$defs/nonEmptyStrings" }
      }
    },
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generationRef", "standardPackages", "capabilities", "adoptionStatus", "gaps"],
      "properties": {
        "generationRef": { "type": "string", "minLength": 3 },
        "standardPackages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "components": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "$ref": "#/$defs/componentFact" }
        },
        "adoptionStatus": { "$ref": "#/$defs/adoptionStatus" },
        "gaps": { "$ref": "#/$defs/gaps" }
      }
    },
    "documentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adrs", "specs", "catalog", "runbooks", "generatedReferences"],
      "properties": {
        "adrs": { "$ref": "#/$defs/documentationHome" },
        "specs": { "$ref": "#/$defs/documentationHome" },
        "catalog": { "$ref": "#/$defs/documentationHome" },
        "runbooks": { "$ref": "#/$defs/documentationHome" },
        "generatedReferences": { "$ref": "#/$defs/documentationHome" }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "verificationCommands", "terminalBoundary", "recoveryClass", "deployable"],
      "properties": {
        "lane": { "type": "string", "minLength": 3 },
        "verificationCommands": { "$ref": "#/$defs/nonEmptyStrings" },
        "terminalBoundary": { "type": "string", "minLength": 20 },
        "recoveryClass": { "$ref": "#/$defs/id" },
        "deployable": { "type": "boolean" },
        "runnerProfiles": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              { "type": "object" }
            ]
          }
        }
      }
    },
    "commercial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "decisionHome"],
      "properties": {
        "status": { "enum": ["not-applicable", "internal", "candidate", "commercial"] },
        "decisionHome": { "type": "string", "minLength": 5 },
        "pricingSourceOfTruth": { "type": "string" },
        "metricsSourceOfTruth": { "type": "string" },
        "guardrails": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "adoption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "gaps"],
      "properties": {
        "status": { "$ref": "#/$defs/adoptionStatus" },
        "gaps": { "$ref": "#/$defs/gaps" }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[-_.][a-z0-9]+)*$" },
    "componentFact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "implementation", "backendOwner", "ownedEffects"],
      "properties": {
        "role": { "$ref": "#/$defs/id" },
        "implementation": { "$ref": "#/$defs/id" },
        "backendOwner": {
          "anyOf": [
            { "$ref": "#/$defs/componentRef" },
            { "type": "null" }
          ]
        },
        "ownedEffects": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "componentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "componentId"],
      "properties": {
        "repository": { "type": "string", "minLength": 3 },
        "componentId": { "$ref": "#/$defs/id" }
      }
    },
    "adoptionStatus": { "enum": ["not-applicable", "not-started", "migrating", "adopted", "gapped"] },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "url", "title"],
      "properties": {
        "type": { "$ref": "#/$defs/id" },
        "url": { "type": "string", "minLength": 3 },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "ownedCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 20 }
      }
    },
    "publicSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name", "location"],
      "properties": {
        "type": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "surface", "direction"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "surface": { "type": "string", "minLength": 1 },
        "direction": { "$ref": "#/$defs/id" }
      }
    },
    "documentationHome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["location", "status"],
      "properties": {
        "location": { "type": "string", "minLength": 1 },
        "status": { "enum": ["present", "not-applicable", "planned"] }
      }
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "owner", "exitCondition"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "description": { "type": "string", "minLength": 10 },
        "owner": { "type": "string", "minLength": 1 },
        "exitCondition": { "type": "string", "minLength": 10 }
      }
    }
  }
}
