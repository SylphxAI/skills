{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SylphxAI/skills/blob/main/skills/incident-standard/references/active-incident-record.schema.json",
  "title": "Active incident command record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "incidentId",
    "severity",
    "status",
    "commandOwner",
    "affectedCapabilities",
    "impact",
    "mitigation",
    "actions",
    "nextDecision",
    "openedAt",
    "updatedAt",
    "evidenceRefs"
  ],
  "properties": {
    "schemaVersion": { "const": "active-incident-record.v1" },
    "incidentId": { "type": "string", "minLength": 1 },
    "severity": { "enum": ["S1", "S2", "S3", "S4"] },
    "status": {
      "enum": ["detected", "investigating", "mitigating", "monitoring", "resolved"]
    },
    "commandOwner": { "type": "string", "minLength": 1 },
    "affectedCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope": { "type": "string", "minLength": 1 },
    "impact": { "type": "string", "minLength": 1 },
    "currentHypothesis": { "type": "string", "minLength": 1 },
    "mitigation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "owner", "action"],
      "properties": {
        "state": { "enum": ["not-started", "in-progress", "verifying", "complete"] },
        "owner": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "owner", "state", "action"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "state": { "enum": ["pending", "in-progress", "blocked", "complete", "canceled"] },
          "action": { "type": "string", "minLength": 1 },
          "evidenceRefs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "nextDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "dueAt", "predicate"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "dueAt": { "type": "string", "format": "date-time" },
        "predicate": { "type": "string", "minLength": 1 }
      }
    },
    "openedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "resolvedAt": { "type": "string", "format": "date-time" },
    "evidenceRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "publicProjectionRef": { "type": "string", "minLength": 1 }
  }
}
