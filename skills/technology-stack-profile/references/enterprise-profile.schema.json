{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SylphxAI/skills/blob/main/skills/technology-stack-profile/references/enterprise-profile.schema.json",
  "title": "Sylphx immutable enterprise profile revision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "kind",
    "profile",
    "selector",
    "defaults",
    "assertions",
    "exceptionPolicy",
    "review",
    "retirement"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "kind": { "const": "EnterpriseProfile" },
    "profile": { "$ref": "#/$defs/profileMetadata" },
    "selector": { "$ref": "#/$defs/selector" },
    "defaults": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/default" }
    },
    "assertions": { "$ref": "#/$defs/assertionSet" },
    "exceptionPolicy": { "$ref": "#/$defs/exceptionPolicy" },
    "review": { "$ref": "#/$defs/review" },
    "retirement": { "$ref": "#/$defs/retirement" }
  },
  "$defs": {
    "kebab": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "profileMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "contentDigest",
        "contentDigestScope",
        "owner",
        "decisionRef",
        "lifecycle",
        "authorityClass",
        "effectiveOn",
        "reviewBy"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/kebab" },
        "revision": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.[1-9][0-9]*$" },
        "contentDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "contentDigestScope": { "const": "canonical-json-excluding:/profile/contentDigest" },
        "owner": { "type": "string", "minLength": 1 },
        "decisionRef": { "type": "string", "pattern": "^references/ADR-[A-Za-z0-9._-]+\\.md$" },
        "lifecycle": {
          "enum": ["candidate", "active", "deprecated", "retired", "withdrawn"]
        },
        "authorityClass": {
          "enum": ["governance-constraint", "selection-default"]
        },
        "effectiveOn": { "type": "string", "format": "date" },
        "reviewBy": { "type": "string", "format": "date" }
      }
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matchAll", "unknownFactPolicy"],
      "properties": {
        "matchAll": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fact", "operator", "values"],
            "properties": {
              "fact": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
              "operator": { "const": "one-of" },
              "values": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "unknownFactPolicy": { "const": "fail-closed" }
      }
    },
    "default": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "assertionIds", "rationale", "constraints"],
      "properties": {
        "key": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" },
        "assertionIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebab" }
        },
        "rationale": { "type": "string", "minLength": 40 },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 20 }
        }
      }
    },
    "assertionSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digestBinding", "factModel", "rules"],
      "properties": {
        "digestBinding": { "const": "profile-content-digest" },
        "factModel": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "componentCollectionPointer",
            "roleField",
            "implementationField",
            "ownedEffectsField"
          ],
          "properties": {
            "componentCollectionPointer": { "const": "/architecture/components" },
            "roleField": { "const": "role" },
            "implementationField": { "const": "implementation" },
            "ownedEffectsField": { "const": "ownedEffects" }
          }
        },
        "rules": {
          "type": "array",
          "minItems": 4,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/selectorOutcomeAssertion" },
              { "$ref": "#/$defs/roleRequirementAssertion" },
              { "$ref": "#/$defs/completionAssertion" }
            ]
          }
        }
      }
    },
    "selectorOutcomeAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "outcomes"],
      "properties": {
        "id": { "$ref": "#/$defs/kebab" },
        "kind": { "const": "selector-outcome" },
        "outcomes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["matched", "unmatched", "unknown", "conflict"],
          "properties": {
            "matched": { "const": "selected" },
            "unmatched": { "const": "not-selected" },
            "unknown": { "const": "blocked" },
            "conflict": { "const": "blocked" }
          }
        }
      }
    },
    "roleRequirementAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "roles",
        "requiredImplementation",
        "forbiddenEffects",
        "implementationMismatchOutcome",
        "forbiddenEffectOutcome"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/kebab" },
        "kind": { "const": "role-requirement" },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebab" }
        },
        "requiredImplementation": { "$ref": "#/$defs/kebab" },
        "forbiddenEffects": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/kebab" }
        },
        "implementationMismatchOutcome": { "const": "violation" },
        "forbiddenEffectOutcome": { "const": "violation" }
      }
    },
    "completionAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "componentSet",
        "denominator",
        "successCondition",
        "successOutcome",
        "emptyComponentSetOutcome",
        "missingFactOutcome",
        "ambiguousRuleOutcome"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/kebab" },
        "kind": { "const": "completion-denominator" },
        "componentSet": { "const": "declared-components" },
        "denominator": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["declared-component-role", "declared-owned-effect"]
          }
        },
        "successCondition": { "const": "every-denominator-item-conforms" },
        "successOutcome": { "const": "conforming" },
        "emptyComponentSetOutcome": { "const": "blocked" },
        "missingFactOutcome": { "const": "blocked" },
        "ambiguousRuleOutcome": { "const": "blocked" }
      }
    },
    "exceptionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "exceptableDefaults",
        "forbiddenDefaults",
        "requiredFields",
        "expiryAction"
      ],
      "properties": {
        "mode": { "const": "typed-expiring" },
        "exceptableDefaults": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" }
        },
        "forbiddenDefaults": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*$" }
        },
        "requiredFields": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "expiryAction": { "const": "fail-closed" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggers"],
      "properties": {
        "triggers": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 20 }
        }
      }
    },
    "retirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predecessor", "successor", "terminal", "retiredRevisionSelectable"],
      "properties": {
        "predecessor": { "type": ["string", "null"] },
        "successor": { "type": ["string", "null"] },
        "terminal": { "type": "string", "minLength": 80 },
        "retiredRevisionSelectable": { "const": false }
      }
    }
  }
}
