{
  "$schema": "./enterprise-profile.schema.json",
  "schemaVersion": 2,
  "kind": "EnterpriseProfile",
  "profile": {
    "id": "technology-stack-profile",
    "revision": "2026-07-19.3",
    "contentDigest": "sha256:27aa67f1b73b04725bcb337db71c70d15e8c3dc2acddf8ac362b19a609a51d5a",
    "contentDigestScope": "canonical-json-excluding:/profile/contentDigest",
    "owner": "SylphxAI/skills",
    "decisionRef": "references/ADR-20260718-backend-web-technology-boundary.md",
    "lifecycle": "active",
    "authorityClass": "governance-constraint",
    "effectiveOn": "2026-07-19",
    "reviewBy": "2026-10-15"
  },
  "selector": {
    "matchAll": [
      {
        "fact": "repository.lifecycle",
        "operator": "one-of",
        "values": [
          "active",
          "commercial",
          "incubating",
          "maintenance",
          "production"
        ]
      },
      {
        "fact": "task.surface",
        "operator": "one-of",
        "values": [
          "language-boundary-audit",
          "migration-completion",
          "product-code",
          "runtime-implementation"
        ]
      }
    ],
    "unknownFactPolicy": "fail-closed"
  },
  "defaults": [
    {
      "key": "engineering.language.backend-required-technology",
      "assertionIds": [
        "backend-role-requirement"
      ],
      "rationale": "Rust is the required production technology for backend runtime and durable business effects.",
      "constraints": [
        "Repair missing or defective backend behavior in Rust.",
        "Do not use TypeScript as backend fallback, dual-run implementation, shadow production, recovery path, or implementation-delay mechanism."
      ]
    },
    {
      "key": "engineering.language.web-required-technology",
      "assertionIds": [
        "web-role-requirement"
      ],
      "rationale": "TypeScript, Bun, and Next are intended production technologies for browser and server-rendered product web.",
      "constraints": [
        "Web may render, compose UI data, and orchestrate calls through backend contracts.",
        "Web must not own backend database mutations, durable queues, backend business effects, backend authorization decisions, or TypeScript backend fallback."
      ]
    },
    {
      "key": "engineering.language.completion-measure",
      "assertionIds": [
        "role-effect-completion"
      ],
      "rationale": "Completion is semantic coverage of declared service roles and effects, not a source-file statistic.",
      "constraints": [
        "Never use .ts file count, repository language totals, Bun process presence, or endpoint-shell parity as completion evidence.",
        "Keep source, validation, deployment, and live-production proof distinct."
      ]
    }
  ],
  "assertions": {
    "digestBinding": "profile-content-digest",
    "factModel": {
      "componentCollectionPointer": "/architecture/components",
      "roleField": "role",
      "implementationField": "implementation",
      "ownedEffectsField": "ownedEffects"
    },
    "rules": [
      {
        "id": "selector-resolution",
        "kind": "selector-outcome",
        "aggregation": "match-all",
        "precedence": [
          "conflict",
          "unmatched",
          "unknown",
          "matched"
        ],
        "outcomes": {
          "matched": "selected",
          "unmatched": "not-selected",
          "unknown": "blocked",
          "conflict": "blocked"
        }
      },
      {
        "id": "owned-effect-classification",
        "kind": "effect-classification",
        "classes": [
          {
            "id": "backend-effect",
            "effects": [
              "backend-authorization-decision",
              "backend-business-effect",
              "backend-database-mutation",
              "durable-queue-consume",
              "durable-queue-publish"
            ]
          },
          {
            "id": "typescript-backend-fallback",
            "effects": [
              "typescript-backend-fallback"
            ]
          }
        ],
        "noMatchDisposition": "unknown",
        "multipleMatchDisposition": "ambiguous",
        "unknownOutcome": "blocked",
        "ambiguousOutcome": "blocked"
      },
      {
        "id": "backend-role-requirement",
        "kind": "role-requirement",
        "roles": [
          "api",
          "backend-service",
          "background-job",
          "controller",
          "critical-path",
          "gateway",
          "queue-consumer",
          "queue-producer",
          "runtime",
          "storage",
          "worker"
        ],
        "requiredImplementation": "rust",
        "effectClassificationId": "owned-effect-classification",
        "effectClassAllowances": [
          {
            "effectClass": "backend-effect",
            "disposition": "allowed"
          },
          {
            "effectClass": "typescript-backend-fallback",
            "disposition": "forbidden"
          }
        ],
        "implementationMismatchOutcome": "violation",
        "forbiddenEffectOutcome": "violation",
        "unmappedEffectClassOutcome": "blocked"
      },
      {
        "id": "web-role-requirement",
        "kind": "role-requirement",
        "roles": [
          "browser",
          "product-web",
          "server-rendered-web",
          "ui-orchestration"
        ],
        "requiredImplementation": "typescript-bun-next",
        "effectClassificationId": "owned-effect-classification",
        "effectClassAllowances": [
          {
            "effectClass": "backend-effect",
            "disposition": "forbidden"
          },
          {
            "effectClass": "typescript-backend-fallback",
            "disposition": "forbidden"
          }
        ],
        "implementationMismatchOutcome": "violation",
        "forbiddenEffectOutcome": "violation",
        "unmappedEffectClassOutcome": "blocked"
      },
      {
        "id": "role-effect-completion",
        "kind": "completion-denominator",
        "componentSet": "declared-components",
        "denominator": [
          "declared-component-role",
          "declared-owned-effect"
        ],
        "successCondition": "every-denominator-item-conforms",
        "successOutcome": "conforming",
        "emptyComponentSetOutcome": "blocked",
        "missingFactOutcome": "blocked",
        "ambiguousRuleOutcome": "blocked"
      }
    ]
  },
  "exceptionPolicy": {
    "mode": "typed-expiring",
    "exceptableDefaults": [],
    "forbiddenDefaults": [
      "engineering.language.backend-required-technology",
      "engineering.language.completion-measure",
      "engineering.language.web-required-technology"
    ],
    "requiredFields": [
      "id",
      "defaultKey",
      "selector",
      "rationale",
      "owner",
      "decisionRef",
      "evidence",
      "expiresOn",
      "recovery",
      "replacementCondition"
    ],
    "expiryAction": "fail-closed"
  },
  "review": {
    "triggers": [
      "A component role or effect cannot be classified deterministically.",
      "A TypeScript/Bun/Next component gains a forbidden backend effect.",
      "A backend fallback, dual-run, shadow, or recovery path appears.",
      "Current evidence shows a selected technology is dominated on correctness, security, privacy, legal, or an explicit task requirement.",
      "Another active profile overlaps this selector and selection key.",
      "The reviewBy date is reached."
    ]
  },
  "retirement": {
    "predecessor": "technology-stack-profile@2026-07-18.3",
    "successor": null,
    "terminal": "An admitted active successor revision covers this selector and all selection keys, Control Plane resolves selected repositories to that successor, all exceptions are closed, and this revision is marked retired.",
    "retiredRevisionSelectable": false
  }
}
