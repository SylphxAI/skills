{
  "name": "sylphx-skills",
  "version": "1.4.1",
  "description": "Public agent skills from SylphxAI — standards, product procedures, and multi-runtime sync for Codex, Claude Code, and Grok Build",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sylphx-skills": "runtime/sylphx-skills.mjs"
  },
  "files": [
